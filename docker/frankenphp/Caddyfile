{
    {$CADDY_GLOBAL_OPTIONS}

    frankenphp {
        {$FRANKENPHP_CONFIG}
    }

    order mercure after encode
    order php_server before file_server
}

{$SERVER_NAME:localhost} {
    root * /app/public

    encode zstd br gzip

    mercure {
        publisher_jwt {env.MERCURE_PUBLISHER_JWT_KEY} {env.MERCURE_PUBLISHER_JWT_ALG}
        subscriber_jwt {env.MERCURE_SUBSCRIBER_JWT_KEY} {env.MERCURE_SUBSCRIBER_JWT_ALG}
        anonymous
        subscriptions
        cors_origins {$MERCURE_CORS_ORIGINS:http://localhost,http://127.0.0.1,http://localhost:8080,http://127.0.0.1:8080,http://localhost:8093,http://127.0.0.1:8093,http://192.168.2.38,http://192.168.2.38:8093,http://server,http://server:8093}
        {$MERCURE_EXTRA_DIRECTIVES}
    }

    php_server
}
